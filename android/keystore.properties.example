# Copy to keystore.properties and fill in before release builds.
# Generate keystore: keytool -genkey -v -keystore concordia-terminal.jks -keyalg RSA -keysize 2048 -validity 10000 -alias concordia
storeFile=../concordia-terminal.jks
storePassword=your-store-password
keyAlias=concordia
keyPassword=your-key-password
